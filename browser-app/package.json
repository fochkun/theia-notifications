{
  "private": true,
  "name": "browser-app",
  "version": "0.0.0",
  "dependencies": {
    "@theia/core": "1.73.1",
    "@theia/editor": "1.73.1",
    "@theia/filesystem": "1.73.1",
    "@theia/markers": "1.73.1",
    "@theia/messages": "1.73.1",
    "@theia/monaco": "1.73.1",
    "@theia/navigator": "1.73.1",
    "@theia/preferences": "1.73.1",
    "@theia/process": "1.73.1",
    "@theia/terminal": "1.73.1",
    "@theia/workspace": "1.73.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "theia-notifications": "0.0.0"
  },
  "devDependencies": {
    "@theia/cli": "1.73.1",
